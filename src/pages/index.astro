<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>chaak</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            background-color: #000;
            width: 100%;
            height: 100%;
            /* Prevent all scrolling */
            overflow: hidden; 
        }
        
        /* Make the link wrapper fill the screen too */
        a {
            display: block;
            width: 100%;
            height: 100%;
            cursor: pointer;
        }

        .full-width-image {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
        }
    </style>
</head>
<body>
    <a href="/collect">
        <img src="/goldcacao.jpg" alt="High Resolution View" class="full-width-image" />
    </a>
</body>
</html>
