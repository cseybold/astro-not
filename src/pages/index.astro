<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image View</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            background-color: #000;
            /* Prevent horizontal scrolling if width becomes larger than viewport */
            overflow-x: hidden; 
        }
        .full-width-image {
            display: block;
            width: 100%;
            height: auto;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <a href="/collect">
        <img src="/IMG_20260310_193719.jpg" alt="High Resolution View" class="full-width-image" />
    </a>
</body>
</html>
